{
  "name": "macrostudio",
  "version": "1.0.0",
  "main": "main.js",
  "author": "Antigravity",
  "description": "MacroStudio Local Companion App",
  "scripts": {
    "dev": "electron .",
    "build": "cd frontend && yarn build && cd .. && electron-builder"
  },
  "build": {
    "appId": "com.macrostudio.app",
    "productName": "MacroStudio",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "frontend/dist/**/*",
      "backend/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}
